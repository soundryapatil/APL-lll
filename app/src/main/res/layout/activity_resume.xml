<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    tools:context=".ResumeActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Name -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Soundrya Patil"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="60dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Roll Number -->
        <TextView
            android:id="@+id/tvRoll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Roll No: 33"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvName"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Phone -->
        <TextView
            android:id="@+id/tvPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📞 9876567894"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvRoll"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Email -->
        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✉ soundrya@gmail.com"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvPhone"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Computer Science Engineering Student"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/holo_blue_dark"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvEmail"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Skills Header -->
        <TextView
            android:id="@+id/tvSkillsHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skills"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Skills Content -->
        <TextView
            android:id="@+id/tvSkills"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="• C, C++, Java, Python&#10;• Data Structures and Algorithms&#10;• Android (Kotlin)&#10;• SQL, GitHub"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvSkillsHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Projects Header -->
        <TextView
            android:id="@+id/tvProjectsHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Projects"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvSkills"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Projects Content -->
        <TextView
            android:id="@+id/tvProjects"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="• Student Management System&#10;• Weather Forecast App"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvProjectsHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Education Header -->
        <TextView
            android:id="@+id/tvEducationHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Education"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvProjects"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Education Content -->
        <TextView
            android:id="@+id/tvEducation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="B.Tech – Computer Science Engineering&#10;D Y Patil College of Engineering and Technology, Kolhapur (2022–2026)"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvEducationHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
